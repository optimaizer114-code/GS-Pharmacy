# ══════════════════════════════════════════════════════════
#   صيدلية الحلول العالمية — إعدادات البيئة
#   انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════════════════

# ─── قاعدة البيانات ────────────────────────────────────────
POSTGRES_DB=pharmacy_db
POSTGRES_USER=pharmacy_user
POSTGRES_PASSWORD=StrongPass123!@#ChangeMe

# ─── الأمان (غيّر هذا المفتاح لا محالة!) ──────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-in-production-MUST-CHANGE

# ─── البيئة ────────────────────────────────────────────────
ENVIRONMENT=production

# ─── CORS - عناوين مسموح لها بالوصول ──────────────────────
# أضف عنوان نطاقك هنا
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://pharmacy.yourdomain.com

# ─── الواجهة الأمامية ──────────────────────────────────────
REACT_APP_API_URL=https://pharmacy.yourdomain.com

# ─── إعدادات اختيارية ──────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480
